# Example .env file for backend

# Pinecone Configuration (for RAG/Vector Search)
PINECONE_API_KEY="pcsk_your_pinecone_api_key_here"
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX_NAME=neuro-index

# Groq API (for LLM Inference - Reports & Chatbot)
# Get your free API key at: https://console.groq.com
GROQ_API_KEY="gsk_your_groq_api_key_here"

# Django Configuration
DJANGO_SECRET_KEY="dev-secret-for-local"
DEBUG=True

